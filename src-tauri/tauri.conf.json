{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonara",
  "version": "0.2.3",
  "identifier": "com.kaungset.sonara",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sonara",
        "minWidth": 1150,
        "minHeight": 646,
        "width": 1280,
        "height": 720,
        "resizable": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' asset: https://asset.localhost http://asset.localhost; img-src 'self' asset: https://asset.localhost http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": ["$HOME/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/kaungset03/sonara/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwNzNDRTIwMEM5RTNGQTYKUldTbVA1NE1JTTV6Y0t2SXZvUXZmUzdXcUlTYzhGaUF6UWFjNGtCN0NoSktMV3VUUVJSWjN5M3YK"
    }
  }
}
